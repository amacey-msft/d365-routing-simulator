# Power Platform environment settings
POWERAPPS_URL=https://make.powerapps.com
PPAC_URL=https://admin.powerplatform.microsoft.com
ENVIRONMENT_ID_OR_NAME=your-environment-name-or-id
D365_BASE_URL=https://yourorg.crm.dynamics.com

# Authentication
AUTH_MODE=interactive
# AUTH_MODE=storageState
STORAGE_STATE_PATH=automation/.auth/storageState.json

# Output
OUTPUT_LOCALE=en-US

# Azure deployment (used by CI/CD workflow)
# Set these as GitHub Secrets, not here
# AZURE_CREDENTIALS=<service-principal-json>
# REGISTRY_LOGIN_SERVER=yourregistry.azurecr.io
# REGISTRY_USERNAME=<acr-username>
# REGISTRY_PASSWORD=<acr-password>
# AZURE_WEBAPP_NAME=d365-routing-guide
